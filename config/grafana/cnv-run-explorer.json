      "title": "All Runs",
      "type": "row"
    },
    {
      "datasource": "${DS_ELASTICSEARCH}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "timestamp" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "uuid" },
            "properties": [
              { "id": "custom.width", "value": 280 },
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Run Detail",
                    "url": "/d/cnv-run-detail/cnv-run-detail?var-uuid=${__value.text}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "testMode" },
            "properties": [
              { "id": "custom.width", "value": 80 }
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "timestamp" }
        ],
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        }
      },
      "title": "Test Runs",
      "description": "Click UUID to drill into run detail",
      "type": "table",
      "targets": [
        {
          "alias": "",
          "bucketAggs": [],
          "metrics": [
            {
              "id": "1",
              "settings": {
                "size": "500"
              },
              "type": "raw_document"
            }
          ],
          "query": "metricName:metadata AND testName.keyword:$testName AND cluster.ocpVersion.keyword:$ocpVersion AND cluster.platform.keyword:$platform",
          "refId": "A",
          "timeField": "timestamp"
        }
      ],
      "transformations": [
        { "id": "extractFields", "options": { "source": "A", "format": "json", "replace": true } },
        { "id": "extractFields", "options": { "source": "cluster", "format": "json", "replace": true } },
        { "id": "extractFields", "options": { "source": "operators", "format": "json", "replace": false } },
        { "id": "extractFields", "options": { "source": "nodes", "format": "json", "replace": false } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "_id": true,
              "_index": true,
              "_type": true,
              "metricName": true,
              "nodes": true,
              "operators": true,
              "storage": true,
              "testConfig": true,
              "apiUrl": true,
              "clusterId": true,
              "highlight": true,
              "sort": true,
              "workerDetails": true,
              "masters": true,
              "total": true,
              "hcoVersion": true,
              "sriovVersion": true,
              "nmstateVersion": true,
              "odfVersion": true
            },
            "indexByName": {
              "timestamp": 0,
              "testName": 1,
              "testMode": 2,
              "uuid": 3,
              "ocpVersion": 4,
              "cnvVersion": 5,
              "platform": 6,
              "networkType": 7,
              "workers": 8,
              "kubeBurnerVersion": 9,
              "runTimestamp": 10
            },
            "renameByName": {
              "ocpVersion": "OCP Version",
              "platform": "Platform",
              "networkType": "Network",
              "cnvVersion": "CNV Version",
              "workers": "Workers",
              "kubeBurnerVersion": "KB Version",
              "testName": "Test",
              "testMode": "Mode",
              "runTimestamp": "Run ID"
            }
          }
        }
      ]
